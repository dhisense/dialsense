{
  "name": "dialsense",
  "version": "1.0.0",
  "description": "Phone number parsing and validation utilities",
  "main": "./dist/core.cjs",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js",
      "require": "./dist/metadata.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./reachability": {
      "types": "./dist/reachability.d.ts",
      "import": "./dist/reachability.js",
      "require": "./dist/reachability.cjs"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.js",
      "require": "./dist/format.cjs"
    },
    "./asYouType": {
      "types": "./dist/asYouType.d.ts",
      "import": "./dist/asYouType.js",
      "require": "./dist/asYouType.cjs"
    },
    "./regions": {
      "types": "./dist/regions.d.ts",
      "import": "./dist/regions.js",
      "require": "./dist/regions.cjs"
    },
    "./metadata/*.json": "./data/*.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/core.ts src/metadata.ts src/types.ts src/reachability.ts src/format.ts src/asYouType.ts src/regions.ts --format esm,cjs --dts --sourcemap --clean --out-dir dist",
    "prepack": "npm run typecheck && npm run build",
    "test": "npm run typecheck && tsx --test $(find tests -type f -name '*.test.ts' | sort)",
    "metadata:extract": "tsx scripts/extract-metadata.ts",
    "metadata:check": "tsx scripts/monitor-upstream.ts"
  },
  "keywords": ["google", "libphonenumber", "libphonenumber-js"],
  "author": "vinpro9",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhisense/dialsense.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
