{
  "name": "dialsense",
  "version": "1.0.0",
  "description": "Phone number parsing and validation utilities",
  "main": "./dist/core.cjs",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js",
      "require": "./dist/metadata.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./metadata/*.json": "./data/*.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "sideEffects": false,
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/core.ts src/metadata.ts src/types.ts --format esm,cjs --dts --sourcemap --clean --out-dir dist",
    "prepack": "npm run typecheck && npm run build",
    "test": "npm run typecheck && tsx --test $(find tests -type f -name '*.test.ts' | sort)",
    "metadata:extract": "tsx scripts/extract-metadata.ts",
    "metadata:check": "tsx scripts/monitor-upstream.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
